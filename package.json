{
  "name": "@omochice/markdown-it-isomorphic-mermaid",
  "version": "1.0.0",
  "description": "A markdown-it plugin that renders mermaid code blocks to SVG using isomorphic-mermaid",
  "keywords": [
    "markdown-it",
    "markdown-it-plugin",
    "mermaid",
    "svg",
    "isomorphic"
  ],
  "license": "Zlib",
  "author": "",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./plugin": {
      "types": "./dist/plugin.d.ts",
      "import": "./dist/plugin.js"
    },
    "./render": {
      "types": "./dist/render.d.ts",
      "import": "./dist/render.js"
    }
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsgo",
    "check": "run-p check:*",
    "check:biome": "biome check",
    "check:type": "tsgo --noEmit",
    "fmt": "run-p fmt:*",
    "fmt:biome": "biome check --write --unsafe",
    "fmt:sort-package-json": "sort-package-json",
    "test": "node --test src/**/*.test.ts"
  },
  "dependencies": {
    "isomorphic-mermaid": "^0.1.1",
    "markdown-it": "^14.1.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.8",
    "@tsconfig/node24": "^24.0.4",
    "@tsconfig/strictest": "^2.0.8",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^25.5.0",
    "@typescript/native-preview": "7.0.0-dev.20260324.1",
    "clean-pkg-json": "^1.4.1",
    "npm-run-all2": "^8.0.4",
    "sort-package-json": "^3.6.1"
  },
  "packageManager": "pnpm@10.32.1",
  "devEngines": {
    "packageManager": {
      "name": "pnpm",
      "onFail": "error"
    }
  }
}
