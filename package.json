{
  "name": "@omochice/markdown-it-isomorphic-mermaid",
  "version": "1.0.0",
  "description": "A markdown-it plugin that renders mermaid code blocks to SVG using isomorphic-mermaid",
  "keywords": [
    "markdown-it",
    "markdown-it-plugin",
    "mermaid",
    "svg",
    "isomorphic"
  ],
  "license": "Zlib",
  "author": "",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "fmt": "run-p fmt:*",
    "fmt:biome": "biome check --write --unsafe",
    "fmt:sort-package-json": "sort-package-json",
    "test": "node --test dist/**/*.test.js"
  },
  "dependencies": {
    "isomorphic-mermaid": "^0.1.1",
    "markdown-it": "^14.1.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.8",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^25.5.0",
    "clean-pkg-json": "^1.4.1",
    "npm-run-all2": "^8.0.4",
    "sort-package-json": "^3.6.1",
    "typescript": "^6.0.2"
  },
  "packageManager": "pnpm@10.32.1"
}
